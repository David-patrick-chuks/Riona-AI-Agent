{
  "name": "riona",
  "version": "1.0.0",
  "private": true,
  "description": "Riona AI Agent monorepo — social media automation (Instagram, X) and reCAPTCHA ML",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter @riona/api dev",
    "dev:api": "pnpm --filter @riona/api dev",
    "dev:recaptcha": "pnpm --filter @riona/recaptcha dev",
    "dev:all": "pnpm -r --parallel dev",
    "start": "pnpm --filter @riona/api start",
    "build": "pnpm -r build",
    "test": "pnpm --filter @riona/api test",
    "test:coverage": "pnpm --filter @riona/api test:coverage",
    "lint": "pnpm --filter @riona/api lint",
    "lint:fix": "pnpm --filter @riona/api lint:fix",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:env": "pnpm --filter @riona/api check:env",
    "setup": "pnpm --filter @riona/api setup",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @riona/api db:migrate",
    "train:link": "pnpm --filter @riona/api train:link",
    "train:audio": "pnpm --filter @riona/api train:audio",
    "train:youtube": "pnpm --filter @riona/api train:youtube",
    "recaptcha:dev": "pnpm --filter @riona/recaptcha dev",
    "recaptcha:train": "pnpm --filter @riona/recaptcha train",
    "recaptcha:collect": "pnpm --filter @riona/recaptcha collect",
    "recaptcha:build": "pnpm --filter @riona/recaptcha build",
    "recaptcha:serve": "pnpm --filter @riona/recaptcha serve",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.5",
    "typescript-eslint": "^8.62.0"
  }
    "express": "^4.18.2",
}

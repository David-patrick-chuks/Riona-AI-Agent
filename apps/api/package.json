{
  "name": "@riona/api",
  "version": "1.0.0",
  "private": true,
  "description": "Riona AI Agent API — Instagram/X automation, admin dashboard, agent loop",
  "main": "build/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "start": "tsc && pnpm run postbuild && node build/index.js",
    "build": "tsc && pnpm run postbuild",
    "postbuild": "copyfiles -u 3 src/Agent/characters/*.json build/Agent/characters && copyfiles -u 2 src/db/schema.sql build/db",
    "train:link": "tsc && node build/Agent/training/WebsiteScraping.js",
    "train:audio": "tsc && node build/Agent/training/TrainWithAudio.js",
    "train:youtube": "tsc && node build/Agent/training/youtubeURL.js",
    "test": "jest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "check:env": "node scripts/check-env.js",
    "setup": "node scripts/setup.js",
    "db:migrate": "node scripts/migrate.js"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "axios": "^1.13.6",
    "cookie-parser": "^1.4.7",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "csv-parser": "^3.2.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "instagram-private-api": "^1.46.1",
    "jsdom": "^29.0.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "moment": "^2.30.1",
    "multer": "^2.0.0",
    "node-cron": "^4.2.1",
    "openai": "^6.16.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "proxy-chain": "^2.7.1",
    "puppeteer": "^24.39.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "readline-sync": "^1.4.10",
    "request": "^2.88.2",
    "request-promise": "^4.2.6",
    "socket.io": "^4.8.3",
    "textract": "^2.5.0",
    "twitter-api-v2": "^1.29.0",
    "user-agents": "^1.1.674",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "youtube-transcript": "^1.3.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@riona/tsconfig": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/puppeteer": "^7.0.4",
    "@types/readline-sync": "^1.4.8",
    "@types/request": "^2.48.13",
    "@types/request-promise": "^4.1.51",
    "@types/textract": "^2.4.5",
    "@types/user-agents": "^1.0.4",
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  }
}
